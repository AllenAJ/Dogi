# Magic (https://dashboard.magic.link) — publishable API key
NEXT_PUBLIC_MAGIC_API_KEY=pk_live_...

# Particle Network (https://dashboard.particle.network) — project credentials
NEXT_PUBLIC_PARTICLE_PROJECT_ID=
NEXT_PUBLIC_PARTICLE_CLIENT_KEY=
NEXT_PUBLIC_PARTICLE_APP_ID=

# Optional: custom Arbitrum RPC (falls back to https://arb1.arbitrum.io/rpc)
# NEXT_PUBLIC_ARB_RPC_URL=

# Optional: testnet mode (Arbitrum Sepolia)
# NEXT_PUBLIC_SETTLEMENT_CHAIN_ID=421614
# NEXT_PUBLIC_SETTLEMENT_USDC_ADDRESS=0x...
